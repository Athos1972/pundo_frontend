{
  "_comment": "PUNDO-REPO - autonomer Modus. Agent Teams ON, großzügige Allow-Liste inkl. psql. WICHTIG: psql ist mächtig - DROP/TRUNCATE sind via Pattern kaum sauber zu blocken. Nutze für Claude einen Postgres-User mit eingeschränkten Rechten (nur auf die Entwicklungs-DB, kein DROP DATABASE). Siehe README-pundo.md.",

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },

  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Skill(*)",
      "WebFetch",

      "Bash(ls:*)", "Bash(cat:*)", "Bash(tree:*)", "Bash(pwd)",
      "Bash(mkdir:*)", "Bash(touch:*)", "Bash(cp:*)", "Bash(mv:*)",
      "Bash(grep:*)", "Bash(sed:*)", "Bash(awk:*)", "Bash(find:*)",
      "Bash(head:*)", "Bash(tail:*)", "Bash(wc:*)", "Bash(sort:*)", "Bash(uniq:*)",

      "Bash(npm:*)", "Bash(npx:*)", "Bash(pnpm:*)", "Bash(yarn:*)", "Bash(node:*)",
      "Bash(python:*)", "Bash(python3:*)", "Bash(pip:*)", "Bash(uv:*)", "Bash(poetry:*)",
      "Bash(pytest:*)", "Bash(ruff:*)", "Bash(black:*)", "Bash(mypy:*)", "Bash(flake8:*)",
      "Bash(eslint:*)", "Bash(prettier:*)", "Bash(tsc:*)", "Bash(vitest:*)", "Bash(jest:*)",
      "Bash(playwright:*)", "Bash(cypress:*)",

      "Bash(psql:*)", "Bash(pg_dump:*)", "Bash(pg_restore:*)", "Bash(PGPASSWORD=*)",

      "Bash(docker:*)", "Bash(docker-compose:*)", "Bash(docker compose:*)",
      "Bash(make:*)", "Bash(just:*)",

      "Bash(git add:*)", "Bash(git commit:*)", "Bash(git status:*)",
      "Bash(git diff:*)", "Bash(git log:*)", "Bash(git branch:*)",
      "Bash(git checkout:*)", "Bash(git switch:*)", "Bash(git merge:*)",
      "Bash(git rebase:*)", "Bash(git pull:*)", "Bash(git fetch:*)",
      "Bash(git push origin:*)", "Bash(git stash:*)", "Bash(git tag:*)",
      "Bash(gh:*)"
    ],

    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /)",
      "Bash(sudo:*)",

      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push --mirror:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git filter-branch:*)",

      "Bash(*DROP DATABASE*)",
      "Bash(*DROP SCHEMA*)",
      "Bash(*TRUNCATE*)",
      "Bash(psql*postgres*)",

      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)"
    ]
  }
}
